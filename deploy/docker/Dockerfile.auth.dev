FROM golang:1.23-alpine

RUN apk add --no-cache git ca-certificates
RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app
ENV GOWORK=off
COPY go.work ./
COPY backend/pkg/go.mod backend/pkg/go.sum* ./backend/pkg/
COPY backend/auth/go.mod backend/auth/go.sum* ./backend/auth/
RUN cd backend/auth && go mod download

COPY backend/pkg ./backend/pkg
COPY backend/auth ./backend/auth

WORKDIR /app/backend/auth
CMD ["air", "-c", ".air.toml"]
