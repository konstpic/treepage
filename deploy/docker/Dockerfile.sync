FROM golang:1.24-alpine AS builder
RUN apk add --no-cache git ca-certificates
WORKDIR /app
ENV GOWORK=off
COPY backend/pkg ./backend/pkg
COPY backend/sync ./backend/sync
WORKDIR /app/backend/sync
RUN go mod download && CGO_ENABLED=0 go build -o /treepage-sync ./cmd

FROM alpine:3.20
RUN apk add --no-cache ca-certificates git wget
COPY --from=builder /treepage-sync /usr/local/bin/treepage-sync
RUN mkdir -p /data/repos
EXPOSE 8083
ENTRYPOINT ["treepage-sync"]
