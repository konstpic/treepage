# Production secrets — copy to .env.prod and fill all required values.
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

DB_PASSWORD=
JWT_SECRET=
INTERNAL_SERVICE_TOKEN=
CSRF_SECRET=
GIT_WEBHOOK_SECRET=
LOG_LEVEL=info
FRONTEND_PORT=80

# OIDC (if used)
OIDC_CLIENT_SECRET=
GIT_ACCESS_TOKEN=

# Optional RAG
LLM_ENABLED=false
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=nomic-embed-text

# Optional object storage
# ATTACHMENTS_STORAGE=s3
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_USE_SSL=true

# Optional notifications
# NOTIFY_WEBHOOK_URL=
# NOTIFY_SLACK_WEBHOOK_URL=
# NOTIFY_SMTP_HOST=
# NOTIFY_SMTP_PORT=587
# NOTIFY_SMTP_FROM=
# NOTIFY_SMTP_USER=
# NOTIFY_SMTP_PASSWORD=

# Optional OpenSearch
# SEARCH_BACKEND=opensearch
# OPENSEARCH_URL=
